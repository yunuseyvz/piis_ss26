{
  "name": "jupyterlab-piis-assistant",
  "version": "0.1.0",
  "description": "A minimal JupyterLab assistant sidebar for the PIIS notebook experiments.",
  "license": "UNLICENSED",
  "type": "module",
  "keywords": [
    "jupyterlab-extension",
    "jupyterlab",
    "assistant",
    "sidebar"
  ],
  "files": [
    "lib/**/*",
    "style/**/*"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "scripts": {
    "clean": "rimraf lib labextension jupyterlab_piis_assistant/labextension tsconfig.tsbuildinfo build jupyterlab_piis_assistant.egg-info",
    "build": "npm run clean && tsc && jupyter labextension build .",
    "watch": "tsc -w --preserveWatchOutput"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.5.0",
    "@jupyterlab/apputils": "^4.5.0",
    "@jupyterlab/services": "^7.5.0",
    "@lumino/widgets": "^2.5.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.5.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlab_piis_assistant/labextension"
  }
}